        </p>
        <div class="tag-row">
          <span class="tag">Cisco</span>
          <span class="tag m">CCNA</span>
          <span class="tag y">Networking</span>
          <span class="tag g">Infrastructure</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- SKILLS -->
<section id="skills">
  <div class="container">
    <p class="section-label">// 03 — Capabilities</p>
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">

      <div class="skill-group">
        <div class="skill-group-title">⚡ Languages</div>
        <div class="skill-item">
          <div class="skill-label"><span>Python</span><span>90%</span></div>
          <div class="skill-bar"><div class="skill-fill" style="width:90%"></div></div>
        </div>
        <div class="skill-item">
          <div class="skill-label"><span>JavaScript</span><span>80%</span></div>
          <div class="skill-bar"><div class="skill-fill" style="width:80%"></div></div>
