  </ul>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <p class="hero-tag">// CS Graduation Portfolio — Holy Angel University</p>
    <h1 class="hero-name">
      <span class="glitch" data-text="ALDRIN">ALDRIN</span>
    </h1>
    <h1 class="hero-name" style="color:#fff; margin-top:.2rem;">MANALOTO</h1>
